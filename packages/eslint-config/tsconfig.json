{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "isolatedModules": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "tsup.config.ts"]
}
